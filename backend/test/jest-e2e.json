{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": {
        "module": "commonjs",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": "..",
        "paths": { "@arafat/shared": ["../../packages/shared/dist"] }
      },
      "isolatedModules": true
    }]
  },
  "moduleNameMapper": {
    "@arafat/shared$": "<rootDir>/../../packages/shared/dist/index.js"
  }
}
